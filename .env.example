# Spotify app credentials (from https://developer.spotify.com/dashboard)
# The app owner must have Spotify Premium; each player's account email must be
# allowlisted under the app's User Management tab (max 5 users in dev mode).
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Must EXACTLY match a Redirect URI registered in the Spotify dashboard.
# Local dev: http://127.0.0.1:5173/callback  (Spotify allows http only for 127.0.0.1)
REDIRECT_URI=http://127.0.0.1:5173/callback

# Server port (the Express + Socket.io backend)
PORT=3001

# Public base URL of the client (used for CORS / redirects). Local dev default:
CLIENT_ORIGIN=http://127.0.0.1:5173

# Secret used to sign session tokens. Generate a random string for real use.
SESSION_SECRET=change_me_to_a_long_random_string
